# Copy to .env and fill in at least one provider key:
#   cp .env.example .env

# Provider priority when LLM_PROVIDER=auto: openai → openrouter → deepseek → groq → anthropic
LLM_PROVIDER=auto

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

GOOGLE_API_KEY=

DEMO_MODE=true
GITHUB_TOKEN=
CORS_ORIGINS=http://localhost:3000,https://agenteval.vercel.app
